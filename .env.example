# Shared bearer token — every agent must send `Authorization: Bearer <this>`.
# Generate one with: openssl rand -hex 32
AGENT_BUS_TOKEN=replace-me-with-a-long-random-secret

# For LOCAL DEV ONLY: run with no auth. Never set this on a reachable host.
# AGENT_BUS_ALLOW_NO_AUTH=1

# Network — the server always binds 0.0.0.0. Railway injects PORT for you.
PORT=7077

# SQLite file — the entire shared state. Back this up and you have everything.
AGENT_BUS_DB=data/agent-bus.db

# Default claim time-to-live in seconds (auto-expiry so a crashed agent can't
# hold a key forever). 0 = claims never expire. Per-claim override via the tool.
AGENT_BUS_CLAIM_TTL=900

# Mark an agent offline after this many seconds without a heartbeat.
AGENT_BUS_STALE_AFTER=120

# --- Release watcher (optional) -------------------------------------------
# Enable the in-process GitHub release-watcher: it polls the repos in
# watchlist.json and broadcasts new releases as PUBLIC messages (visible on
# /feed.xml + /feed.json). Off unless set to 1.
# AGENT_BUS_WATCH=1
#
# Required when the watcher is enabled. A GitHub token raises the API rate limit
# from 60/hr (unauthenticated) to 5000/hr — needed to poll ~70 repos — and lets
# the watcher see any PRIVATE repos the token has access to. A fine-grained or
# classic token with read-only "Contents" / public_repo scope is enough.
# GITHUB_TOKEN=ghp_xxx
#
# Seconds between polls (default 900 = 15 min).
# AGENT_BUS_WATCH_INTERVAL=900
#
# Override the watchlist path (default: bundled ./watchlist.json).
# AGENT_BUS_WATCHLIST=/data/watchlist.json
